  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "string"
      }
    },
    "schemas": {
      "SofkUiErrorDto": {
        "type": "object",
        "description": "Ошибки при выполнении запроса",
        "additionalProperties": false,
        "properties": {
          "time": {
            "type": "string",
            "format": "date-time",
            "description": "Время ответа",
            "pattern": "^[0-9]{4}-((0[1-9])|(1[0-2]))-[0-9]{2}(T[0-9]{2}:[0-9]{2}:[0-9]{2}(()|(.[0-9]{1,6})(Z|([+-](0[0-9]|1[0-2]):([0-5][0-9])))|(.[0-9]{1,6}))|)$"
          },
          "status": {
            "type": "integer",
            "format": "int32",
            "minimum": 0,
            "maximum": 2147483647,
            "description": "Код ответа"
          },
          "error": {
            "type": "string",
            "maxLength": 255,
            "description": "Причина ошибки"
          },
          "message": {
